<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HORIZONTAL GUIDELINES -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.20" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_middle_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.80" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_bot_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.90" />

    <!-- VERTICAL GUIDELINES -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_33"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.33" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_66"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.66" />


    <!-- ======================= -->
    <!--     TOP SEGMENT         -->
    <!-- ======================= -->
    <com.example.rexray_vision.HistogramView
        android:id="@+id/histogramView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50"
        app:layout_constraintBottom_toTopOf="@id/guideline_top_end" />

    <Button
        android:id="@+id/closeAppButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Close App"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline_top_end" />

    <!-- ======================= -->
    <!--    MIDDLE SEGMENT       -->
    <!-- ======================= -->

    <!-- Col 1 -->
    <Button
        android:id="@+id/stopServerButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stop_server"
        app:layout_constraintTop_toBottomOf="@id/guideline_top_end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_33" />

    <LinearLayout
        android:id="@+id/clientListContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_margin="8dp"
        android:background="@drawable/rounded_black_bg"
        app:layout_constraintTop_toBottomOf="@id/stopServerButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_33"
        app:layout_constraintBottom_toTopOf="@id/guideline_middle_end" >
        <TextView
            android:id="@+id/clientListHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connected_clients"
            android:textColor="@android:color/white"
            android:gravity="center_horizontal"
            android:padding="8dp"/>
        <ListView
            android:id="@+id/clientListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Col 2 -->
    <TextView
        android:id="@+id/settingsDisplayTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/rounded_black_bg"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="@android:color/white"
        tools:text="ISO: 400\nS: 1/300\nFPS: 5\nLimit: 5"
        app:layout_constraintBottom_toTopOf="@id/guideline_middle_end"
        app:layout_constraintStart_toEndOf="@id/guideline_v_33"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_66" />

    <!-- Col 3 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settingsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@drawable/rounded_black_bg"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/guideline_top_end"
        app:layout_constraintStart_toEndOf="@id/guideline_v_66"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline_middle_end">

        <TextView
            android:id="@+id/isoValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            tools:text="ISO: 100"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/autoIsoIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTO"
            android:textColor="@android:color/holo_red_light"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/isoValueTextView"
            app:layout_constraintBottom_toBottomOf="@id/isoValueTextView"
            app:layout_constraintStart_toEndOf="@id/isoValueTextView"
            android:layout_marginStart="8dp"/>

        <SeekBar
            android:id="@+id/isoSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/isoValueTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/shutterSpeedValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            tools:text="1/1000s"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/isoSeekBar"
            app:layout_constraintStart_toStartOf="parent"/>
        <SeekBar
            android:id="@+id/shutterSpeedSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/shutterSpeedValueTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/captureRateValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            tools:text="10fps"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/shutterSpeedSeekBar"
            app:layout_constraintStart_toStartOf="parent"/>
        <SeekBar
            android:id="@+id/captureRateSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/captureRateValueTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/captureLimitValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            tools:text="Limit: 5"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/captureRateSeekBar"
            app:layout_constraintStart_toStartOf="parent"/>
        <SeekBar
            android:id="@+id/captureLimitSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/captureLimitValueTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/analyzeSceneButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto-ISO"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ======================= -->
    <!--     BOT SEGMENT         -->
    <!-- ======================= -->
    <LinearLayout
        android:id="@+id/nameContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android.background="@drawable/rounded_black_bg"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/guideline_middle_end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50"
        app:layout_constraintBottom_toTopOf="@id/guideline_bot_middle">
        <TextView
            android:id="@+id/projectNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@android:color/white"
            tools:text="Project: Calm-Map" />
        <TextView
            android:id="@+id/cameraNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@android:color/white"
            tools:text="Camera: Puma" />
    </LinearLayout>

    <Button
        android:id="@+id/newProjectButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Project"
        app:layout_constraintTop_toBottomOf="@id/guideline_bot_middle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_v_50"
        app:layout_constraintBottom_toBottomOf="parent" />

    <Button
        android:id="@+id/armButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Arm"
        app:layout_constraintTop_toBottomOf="@id/guideline_middle_end"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline_bot_middle" />

    <Button
        android:id="@+id/captureButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Capture"
        app:layout_constraintTop_toBottomOf="@id/guideline_bot_middle"
        app:layout_constraintStart_toEndOf="@id/guideline_v_50"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
