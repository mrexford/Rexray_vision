<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- GUIDELINES -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/safeTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="48dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/safeBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="48dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/midV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/midH"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <!-- TOP-LEFT: CLIENT LIST -->
    <LinearLayout
        android:id="@+id/clientListContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@drawable/rounded_black_bg"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/midH"
        app:layout_constraintEnd_toStartOf="@+id/midV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/safeTop">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONNECTED CLIENTS"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/clientListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- RIGHT-CENTER: SETTINGS -->
    <LinearLayout
        android:id="@+id/settingsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/rounded_black_bg"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/midV"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/isoValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            tools:text="ISO: 400" />

        <SeekBar
            android:id="@+id/isoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/shutterSpeedValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            tools:text="SHUTTER: 1/300" />

        <SeekBar
            android:id="@+id/shutterSpeedSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/captureRateValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            tools:text="FPS: 5" />

        <SeekBar
            android:id="@+id/captureRateSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/captureLimitValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            tools:text="LIMIT: 30" />

        <SeekBar
            android:id="@+id/captureLimitSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp" />

        <Button
            android:id="@+id/analyzeSceneButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#6200EE"
            android:text="ANALYZE SCENE" />
    </LinearLayout>

    <!-- BOTTOM-LEFT STATUS STACK -->
    <com.example.rexray_vision.HistogramView
        android:id="@+id/histogramView"
        android:layout_width="140dp"
        android:layout_height="100dp"
        android:layout_margin="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/midH" />

    <LinearLayout
        android:id="@+id/projectInfoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:background="#A0000000"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@+id/newProjectButton"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/projectNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            tools:text="Project: Default" />

        <TextView
            android:id="@+id/cameraNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            tools:text="Camera: Server" />
    </LinearLayout>

    <TextView
        android:id="@+id/captureCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@+id/projectInfoContainer"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="30"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/settingsDisplayTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_black_bg"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@+id/armButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="ISO: 400 | S: 1/300" />

    <!-- PRIMARY ACTION ROW (Weighted Chain) -->
    <Button
        android:id="@+id/newProjectButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:text="NEW PROJECT"
        app:layout_constraintBottom_toTopOf="@+id/stopServerButton"
        app:layout_constraintEnd_toStartOf="@+id/armButton"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/armButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:text="ARM SYSTEM"
        app:layout_constraintBottom_toBottomOf="@+id/newProjectButton"
        app:layout_constraintEnd_toStartOf="@+id/captureButton"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@+id/newProjectButton" />

    <Button
        android:id="@+id/captureButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:enabled="false"
        android:text="START CAPTURE"
        app:layout_constraintBottom_toBottomOf="@+id/newProjectButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@+id/armButton" />

    <Button
        android:id="@+id/saveResetButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:backgroundTint="#4CAF50"
        android:text="SAVE &amp; RESET"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/captureButton"
        app:layout_constraintEnd_toEndOf="@+id/captureButton"
        app:layout_constraintStart_toStartOf="@+id/captureButton"
        tools:visibility="gone" />

    <!-- EXIT ACTIONS -->
    <Button
        android:id="@+id/stopServerButton"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STOP SERVER"
        android:textColor="#FF5252"
        app:layout_constraintBottom_toBottomOf="@+id/safeBottom"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/closeAppButton"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CLOSE APP"
        android:textColor="#FF5252"
        app:layout_constraintBottom_toBottomOf="@+id/safeBottom"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OVERLAYS -->
    <TextView
        android:id="@+id/autoIsoIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="AUTO-ISO ACTIVE"
        android:textColor="#FF0000"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@+id/histogramView"
        app:layout_constraintTop_toTopOf="@+id/histogramView" />

    <!-- MIGRATION OVERLAY -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/migrationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:elevation="100dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_black_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/migrationStatusTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processing..."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/migrationProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/migrationProgressTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0%"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
